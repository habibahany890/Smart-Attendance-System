#include <SPI.h>
#include <MFRC522.h>
#include <WiFi.h>
#include <WebServer.h>
#include <LiquidCrystal_I2C.h>
#include <SPIFFS.h>
#include <ThreeWire.h>  
#include <RtcDS1302.h>

// --- إعدادات الهاردوير ---
ThreeWire myWire(27, 26, 25); // IO, SCLK, CE
RtcDS1302<ThreeWire> Rtc(myWire);

#define RFID_SS 2
#define RFID_RST 4
MFRC522 mfrc522(RFID_SS, RFID_RST);

LiquidCrystal_I2C lcd(0x27, 16, 2);
WebServer server(80);

const int buzzerPin = 15;
String lastScannedUID = ""; 

String getNowTime() {
    RtcDateTime now = Rtc.GetDateTime();
    char buf[20];
    snprintf(buf, sizeof(buf), "%02u:%02u:%02u", now.Hour(), now.Minute(), now.Second());
    return String(buf);
}

void setup() {
    pinMode(buzzerPin, OUTPUT); 
    digitalWrite(buzzerPin, HIGH); 
    Serial.begin(115200);
    
    Wire.begin(21, 22);
    lcd.init(); 
    lcd.backlight();
    lcd.print("FCI System V3");

    SPI.begin(18, 19, 23, RFID_SS);
    mfrc522.PCD_Init();
    Rtc.Begin();

    if(!SPIFFS.begin(true)) { Serial.println("SPIFFS Mount Error!"); }

    WiFi.softAP("FCI_Attendance_06", "006007008");

    // --- المسارات (Routes) ---
    auto handleRoot = [](){
        File f = SPIFFS.open("/index.html", "r");
        server.streamFile(f, "text/html");
        f.close();
    };

    server.on("/", HTTP_GET, handleRoot);
    server.on("/admin", HTTP_GET, handleRoot);
    server.on("/mapping", HTTP_GET, handleRoot);
    server.on("/students", HTTP_GET, handleRoot); 

    server.on("/get-uid", HTTP_GET, [](){
        server.send(200, "application/json", "{\"uid\":\"" + lastScannedUID + "\"}");
    });

    server.on("/get-names", HTTP_GET, [](){
        String lvl = server.arg("lvl");
        File f = SPIFFS.open("/level" + lvl + ".txt", "r");
        if (!f) { server.send(404); return; }
        server.setContentLength(CONTENT_LENGTH_UNKNOWN);
        server.send(200, "text/html", "");
        server.sendContent("<option value=''>اختر الاسم</option>");
        while (f.available()) {
            String n = f.readStringUntil('\n');
            n.trim();
            if(n.length() > 0) server.sendContent("<option value='" + n + "'>" + n + "</option>");
        }
        f.close();
        server.sendContent("");
    });

    server.on("/get-level-content", HTTP_GET, [](){
        String lvl = server.arg("lvl");
        File f = SPIFFS.open("/level" + lvl + ".txt", "r");
        if (f) { server.streamFile(f, "text/plain"); f.close(); }
        else { server.send(200, "text/plain", ""); }
    });

    server.on("/save-level-content", HTTP_POST, [](){
        String lvl = server.arg("lvl");
        String content = server.arg("plain"); 
        File f = SPIFFS.open("/level" + lvl + ".txt", FILE_WRITE);
        if (f) {
            f.print(content);
            f.close();
            server.send(200, "text/plain", "OK");
        } else {
            server.send(500, "text/plain", "Error");
        }
    });

    server.on("/save_mapping", HTTP_POST, [](){
        String u = server.arg("uid");
        String n = server.arg("student_name");
        u.trim(); n.trim();
        File f1 = SPIFFS.open("/mapping.csv", FILE_APPEND);
        if(f1) { f1.println(u + "," + n); f1.close(); }
        File f2 = SPIFFS.open("/attendance.csv", FILE_APPEND);
        if(f2) { f2.printf("%s,%s,%s\n", n.c_str(), u.c_str(), getNowTime().c_str()); f2.close(); }
        lastScannedUID = ""; 
        digitalWrite(buzzerPin, LOW); delay(150); digitalWrite(buzzerPin, HIGH); 
        server.send(200);
    });

    server.on("/get-attendance", HTTP_GET, [](){
        File f = SPIFFS.open("/attendance.csv", "r");
        server.streamFile(f, "text/plain"); f.close();
    });

    server.on("/delete-attendance-row", HTTP_POST, [](){
        String newData = server.arg("plain");
        File f = SPIFFS.open("/attendance.csv", FILE_WRITE);
        if(f) { f.print(newData); f.close(); server.send(200); }
    });

    server.on("/get-mapping-data", HTTP_GET, [](){
        File f = SPIFFS.open("/mapping.csv", "r");
        server.streamFile(f, "text/plain"); f.close();
    });

    server.on("/update-mapping", HTTP_POST, [](){
        String newData = server.arg("plain");
        File f = SPIFFS.open("/mapping.csv", FILE_WRITE);
        if(f) { f.print(newData); f.close(); server.send(200); }
    });

    server.on("/clearAtt", HTTP_GET, [](){
        SPIFFS.remove("/attendance.csv");
        server.sendHeader("Location", "/admin");
        server.send(303);
    });

    server.on("/clearMapping", HTTP_GET, [](){
        SPIFFS.remove("/mapping.csv");
        server.sendHeader("Location", "/mapping");
        server.send(303);
    });

    server.on("/downloadAtt", HTTP_GET, [](){
        File f = SPIFFS.open("/attendance.csv", "r");
        server.sendHeader("Content-Disposition", "attachment; filename=attendance.csv");
        server.streamFile(f, "text/csv"); f.close();
    });

    server.begin();
    lcd.clear(); lcd.print("System Ready!");
}

void loop() {
    server.handleClient();
    if (mfrc522.PICC_IsNewCardPresent() && mfrc522.PICC_ReadCardSerial()) {
        String uid = "";
        for (byte i = 0; i < mfrc522.uid.size; i++) {
            uid += String(mfrc522.uid.uidByte[i] < 0x10 ? "0" : "");
            uid += String(mfrc522.uid.uidByte[i], HEX);
        }
        uid.toUpperCase(); uid.trim();
        lcd.clear(); lcd.print("ID: " + uid);

        bool found = false;
        String studentName = "";
        File f = SPIFFS.open("/mapping.csv", "r");
        if(f){
            while(f.available()){
                String line = f.readStringUntil('\n');
                line.trim();
                if(line.length() > 0 && line.indexOf(',') != -1){
                    String storedUid = line.substring(0, line.indexOf(','));
                    if(storedUid.equalsIgnoreCase(uid)){
                        studentName = line.substring(line.indexOf(',') + 1);
                        found = true; break;
                    }
                }
            }
            f.close();
        }

        if(found){
            bool alreadyIn = false;
            File logRead = SPIFFS.open("/attendance.csv", "r");
            if(logRead){
                while(logRead.available()){
                    if(logRead.readStringUntil('\n').indexOf(uid) != -1){ alreadyIn = true; break; }
                }
                logRead.close();
            }
            if(!alreadyIn){
                File log = SPIFFS.open("/attendance.csv", FILE_APPEND);
                if(log){ log.printf("%s,%s,%s\n", studentName.c_str(), uid.c_str(), getNowTime().c_str()); log.close(); lcd.setCursor(0, 1); lcd.print("Logged OK!"); }
            } else { lcd.setCursor(0, 1); lcd.print("Already Logged!"); }
        } else {
            lastScannedUID = uid;
            lcd.setCursor(0, 1); lcd.print("Unregistered!");
        }
        digitalWrite(buzzerPin, LOW); delay(200); digitalWrite(buzzerPin, HIGH); 
        delay(2500); lcd.clear(); lcd.print("FCI Attendance");
        mfrc522.PICC_HaltA(); mfrc522.PCD_StopCrypto1();
    }
}
